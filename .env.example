# Required by docker-compose.yml. Replace with a strong value, e.g. openssl rand -hex 12
DB_PASSWORD=CHANGE_ME_0123456789abcdef01234567
DATABASE_URL=postgresql://biuro:CHANGE_ME_0123456789abcdef01234567@localhost:5432/autonomiczne_biuro
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GOOGLE_API_KEY=your_google_api_key
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.0-flash
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SLACK_SIGNING_SECRET=your_slack_signing_secret
DISCORD_WEBHOOK_SECRET=your_discord_webhook_secret
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
PORT=3100
HEARTBEAT_INTERVAL_MS=30000
MAX_CONCURRENT_HEARTBEATS=20
LOG_LEVEL=info
AUTH_ENABLED=true
WORKSPACE_ROOT=/tmp/biuro-workspace
