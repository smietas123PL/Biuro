# =========================
# Core
# =========================

# Required by docker-compose.yml. Replace with a strong value, e.g. openssl rand -hex 12
DB_PASSWORD=change_me
DATABASE_URL=postgresql://biuro:change_me@localhost:5432/autonomiczne_biuro

# At least one LLM provider key is typically needed for useful agent execution
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
GOOGLE_API_KEY=your_google_api_key

# =========================
# Models
# =========================

OPENAI_EMBEDDING_MODEL=text-embedding-3-small
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.0-flash

# Optional JSON map of per-model pricing overrides:
# {"claude-sonnet-4-20250514":{"input_per_million_usd":3,"output_per_million_usd":15}}
LLM_PRICING_OVERRIDES=

# =========================
# Marketplace / CORS
# =========================

TEMPLATE_MARKETPLACE_URL=https://marketplace.biuro.ai/templates.json
TEMPLATE_MARKETPLACE_CACHE_TTL_MS=300000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
TRUSTED_PROXY_IPS=

# =========================
# Incoming integrations
# =========================

SLACK_SIGNING_SECRET=your_slack_signing_secret
DISCORD_WEBHOOK_SECRET=your_discord_webhook_secret

# =========================
# Runtime / workspace
# =========================

REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@localhost:6379
DB_TRANSACTION_RETRY_MAX=2
DB_TRANSACTION_RETRY_BASE_DELAY_MS=25
DB_TRANSACTION_RETRY_MAX_DELAY_MS=250
APP_VERSION=0.1.0
CSRF_PROTECTION_ENABLED=true
# REQUIRED in production: generate with `openssl rand -hex 32`
# Minimum length: 32 characters
# Server will refuse to start in production if this is left as the default value
CSRF_SECRET=dev-csrf-secret-please-change-2026
POLICY_CACHE_TTL_MS=30000
WORKSPACE_ROOT=./workspace

BASH_SANDBOX_MODE=docker
BASH_SANDBOX_DOCKER_BINARY=docker
BASH_SANDBOX_IMAGE=alpine/git:2.47.2
BASH_SANDBOX_WORKDIR=/workspace
BASH_SANDBOX_TIMEOUT_MS=10000
BASH_SANDBOX_MEMORY_MB=256
BASH_SANDBOX_CPU_LIMIT=1
BASH_SANDBOX_PIDS_LIMIT=64
BASH_SANDBOX_USER=65534:65534
BASH_SANDBOX_ALLOWED_BINARIES=git,ls,pwd,cat,grep,rg,find,sed,awk,head,tail,wc,sort,uniq,cut,printf,stat,test,mkdir,cp,mv,touch,node,npm,pnpm,npx,tsx,tsc,vite,python,python3,pytest

EVENT_BUS_CHANNEL=biuro:events
SCHEDULER_STREAM_KEY=biuro:scheduler:wakeups
SCHEDULER_STREAM_BLOCK_MS=1000
SCHEDULER_ERROR_BACKOFF_MIN_MS=500
SCHEDULER_ERROR_BACKOFF_MAX_MS=10000

LLM_ROUTER_ENABLED=true
LLM_ROUTER_FALLBACK_ORDER=gemini,claude,openai
LLM_MOCK_MODE=false

# =========================
# Auth / network limits
# =========================

AUTH_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
REST_RATE_LIMIT_WINDOW_MS=60000
REST_RATE_LIMIT_MAX=100
LLM_RATE_LIMIT_WINDOW_MS=60000
LLM_RATE_LIMIT_MAX=20
WS_RATE_LIMIT_WINDOW_MS=60000
WS_RATE_LIMIT_MAX=30

# =========================
# Server / worker
# =========================

PORT=3100
HEARTBEAT_INTERVAL_MS=30000
MAX_HEARTBEATS_PER_HOUR=60
MAX_CONCURRENT_HEARTBEATS=20
DAILY_DIGEST_ENABLED=true
DAILY_DIGEST_HOUR_UTC=18
DAILY_DIGEST_MINUTE_UTC=0
DAILY_DIGEST_SWEEP_INTERVAL_MS=60000
LOG_LEVEL=info
WORKER_METRICS_PORT=9464
# Set to "production" in production deployments
NODE_ENV=development

# =========================
# Observability
# =========================

OTEL_SERVICE_NAME=autonomiczne-biuro
OTEL_TRACE_CONSOLE_EXPORTER=false
OTEL_TRACE_HISTORY_LIMIT=200
OTEL_EXPORTER_OTLP_ENDPOINT=

# Docker host port overrides
OTEL_COLLECTOR_HOST_PORT=4318
WORKER_METRICS_HOST_PORT=9464
TEMPO_HOST_PORT=3202
GRAFANA_ADMIN_PASSWORD=zmien_to_mocne_haslo
